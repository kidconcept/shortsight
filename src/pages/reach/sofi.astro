---
import BaseLayout from '../../layouts/BasicBitch.astro';
const pageTitle = "Principal Product Designer";

import Thumb from '../../components/Thumb.astro';
const allPosts = Object.values(import.meta.glob('../work/**/*.md', { eager: true }));

const featuredCompanies = [
  'morganstanley',
  'travel',
  'enrollment123',
  'advisor-software-design-system',
  'idiligence',
];

const featuredPosts = allPosts
  .filter(post =>
    featuredCompanies.includes(post.frontmatter.slug)
  )
  .sort((a, b) =>
    featuredCompanies.indexOf(a.frontmatter.slug) -
    featuredCompanies.indexOf(b.frontmatter.slug)
  );


---
<BaseLayout pageTitle={pageTitle}>
	<div class="grid">
		<div class="hello">
			<p>Hello SoFi.</p> 
			<p>I am a principal-caliber product designer with a decade of fintech experience building mobile and web products at scale. At Morgan Stanley I led design across internal financial tools used by tens of thousands of employees, delivering time savings of up to ten times on critical workflows and reducing frustration by 75%. At Enrollment123 I redesigned onboarding flows and improved conversions by 30%. I have built design systems from the ground up, designed investment and due diligence platforms, and my AI-powered workflows with Figma and GitHub Copilot have dramatically compressed my output without sacrificing craft. I know how to set a vision, move cross-functional teams, and ship in regulated environments.
			</p>
		</div>
	</div>

	<hr>

	<h3>Some of my work</h3>

	<div class="grid works">
	  	{featuredPosts.map((post: any) => 
	  		<Thumb 
	  			url={post.url} 
	  			title={post.frontmatter.title} 
	  			src={post.frontmatter.src} 
	  			alt={post.frontmatter.alt} 
	  			category={post.frontmatter.category} 
	  			company={post.frontmatter.company}
	  			summary={post.frontmatter.summary}
	  		/>
	  	)}
	</div>

	<div class="grid quotes">
		<h3>What my coworkers are saying</h3>
		<div class="card">
			<div class="pic">
				<img src="/media/demane.jpg">
			</div>
			<div class="text">
				<p class="quote">"Dan is a brilliant UX developer, and a great person. I have had the opportunity to work with Dan over a few years on a number of projects and he is often the most valuable member of the project team."</p>
				<p class="name">Demane Rodney</p>
				<p class="role">Executive Director at Morgan Stanley</p>
			</div>
		</div>
		<div class="card">
			<div class="pic">
				<img src="/media/ben.jpg">
			</div>
			<div class="text">
				<p class="quote">"I know him as someone who I can count on to deliver not only excellent design solutions, but powerful digital strategies to back them up. He's a pleasure to work with, and will deliver the goods every time."</p>
				<p class="name">Ben Thompson</p>
				<p class="role">UX Director at Kaiser Permanente</p>
			</div>
		</div>
	</div>

	<div class="grid skills">
		<div class="card">
			<img src="/media/goodwithpeople.jpg">
			<h2>Fintech at scale</h2>
			<p>I have spent years designing financial products for institutions that operate under strict regulatory constraints. I understand the balance between compliance and great member experience — and I know how to bring Compliance, Risk, and Legal into the design process early so that ships land cleanly. My work at Morgan Stanley touched workflows across a 70,000-person organization and my investment platform experience spans consumer, advisor, and back-office contexts.</p>
		</div>
		<div class="card">
			<img src="/media/AIDriven.jpg">
			<h2>AI driven</h2>
			<p>I use AI in every stage of product development — from Figma AI and Make for rapid prototyping to GitHub Copilot for production-quality front-end code. I have developed team-level workflows that accelerate exploration, testing, and documentation without sacrificing craft. Being a power user of these tools is now core to how I operate at principal level.</p>
		</div>
		<div class="card">
			<img src="/media/realresearch.jpg">
			<h2>Research and data</h2>
			<p>My background in formal research informs how I instrument, measure, and learn from what I ship. I have led research sessions across five global regions, run usability studies that quantified the impact of design decisions in hours and dollars, and used that data to build alignment at the executive level. I tie craft to outcomes.</p>
		</div>
		<div class="card">
			<img src="/media/multisector.jpg">
			<h2>Systems thinking</h2>
			<p>I have built design systems from scratch and scaled them across web, iOS, and Android surfaces. I think at the pattern and token level — not just the screen level — and I design journeys that hold together across the full product ecosystem. At SoFi that means connecting Save, Invest, Protect, and Spend into experiences that feel like one product.</p>
		</div>
	</div>

	<div class="letstalk" id="contact">
		<h1>I would love to talk about SoFi's SIPS ecosystem and how my fintech experience could help raise the bar for your members.</h1>
		<p>I'm available via <a href="mailto:hello@danvallentyne.com">email</a>.</p>
	</div>



</BaseLayout>
