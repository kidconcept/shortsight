---
// Standalone page — intentionally no layout so the auth guard is NOT included here.
// Edit src/data/users.ts to change the password hash or authorized usernames.
import { PASSWORD_HASH, AUTHORIZED_USERS } from '../data/users.ts';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Password Required</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Merriweather:ital,opsz,wght@0,18..144,300..900;1,18..144,300..900&family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --text: #000;
        --muted: #828282;
        --blue: #1189d8cc;
        --corners: 0.8rem;
      }

      *, *::before, *::after { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Open Sans", sans-serif;
        font-weight: 300;
        font-size: clamp(16px, 1.5vw, 22px);
        -webkit-font-smoothing: antialiased;
        background: #fff;
        color: var(--text);
      }

      .gate {
        width: min(400px, 90vw);
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
      }

      h1 {
        font-family: "Merriweather", serif;
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        margin: 0 0 0.2rem;
      }

      p {
        margin: 0;
        color: var(--muted);
        font-size: 0.95em;
      }

      form {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.6rem;
        margin-top: 0.4rem;
        width: 100%;
      }

      input[type="text"],
      input[type="password"] {
        width: 100%;
        padding: 0.65rem 0.9rem;
        font-family: inherit;
        font-size: 1rem;
        font-weight: 300;
        border: 1px solid #ccc;
        border-radius: var(--corners);
        outline: none;
        transition: border-color 0.15s;
      }

      input[type="text"]:focus,
      input[type="password"]:focus {
        border-color: #1189d8;
      }

      button {
        width: 100%;
        padding: 0.65rem 1.4rem;
        font-family: inherit;
        font-size: 1rem;
        font-weight: 400;
        background: var(--text);
        color: #fff;
        border: none;
        border-radius: var(--corners);
        cursor: pointer;
        transition: opacity 0.15s;
      }

      button:hover { opacity: 0.75; }

      #error {
        display: none;
        color: #c0392b;
        font-size: 0.88em;
        margin-top: -0.4rem;
      }
    </style>
  </head>
  <body>
    <div class="gate">
      <h1>Private Portfolio</h1>
      <p>Enter the password to continue.</p>
      <form id="pw-form">
        <input
          type="text"
          id="un-input"
          placeholder="Username"
          autocomplete="username"
          autofocus
        />
        <input
          type="password"
          id="pw-input"
          placeholder="Password"
          autocomplete="current-password"
        />
        <button type="submit">Enter</button>
      </form>
      <p id="error">Incorrect password — try again.</p>
    </div>

    <script is:inline define:vars={{ HASH: PASSWORD_HASH, USERS: AUTHORIZED_USERS }}>
      // Already authenticated? Skip straight to the destination.
      if (sessionStorage.getItem('auth') === HASH &&
          USERS.map(function(u){return u.toLowerCase();}).includes(
            (sessionStorage.getItem('auth_user') || '').toLowerCase()
          )) {
        var dest = new URLSearchParams(window.location.search).get('from') || '/';
        window.location.replace(dest);
      }

      document.getElementById('pw-form').addEventListener('submit', async function (e) {
        e.preventDefault();
        var username = document.getElementById('un-input').value.trim().toLowerCase();
        var pw = document.getElementById('pw-input').value;
        var encoded = new TextEncoder().encode(pw);
        var hashBuffer = await crypto.subtle.digest('SHA-256', encoded);
        var hashHex = Array.from(new Uint8Array(hashBuffer))
          .map(function (b) { return b.toString(16).padStart(2, '0'); })
          .join('');

        var validUsers = USERS.map(function (u) { return u.toLowerCase(); });
        if (hashHex === HASH && validUsers.includes(username)) {
          sessionStorage.setItem('auth', HASH);
          sessionStorage.setItem('auth_user', username);
          var redirect = new URLSearchParams(window.location.search).get('from') || '/';
          window.location.replace(redirect);
        } else {
          document.getElementById('error').style.display = 'block';
          document.getElementById('pw-input').value = '';
          document.getElementById('pw-input').focus();
        }
      });
    </script>
  </body>
</html>
